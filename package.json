{
  "name": "vardag",
  "version": "0.1.0",
  "private": true,
  "description": "A self-hosted, mobile-first family organizer PWA.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Roinur/Vardag.git"
  },
  "keywords": ["pwa", "family", "tasks", "supabase", "self-hosted"],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173",
    "test:parser": "node scripts/check-parser.mjs",
    "test:i18n": "node scripts/check-i18n.mjs",
    "test:scope": "node scripts/check-scope.mjs",
    "lint": "tsc -b --pretty false"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@vitejs/plugin-react": "^4.3.4",
    "dexie": "^4.0.11",
    "lucide-react": "^0.469.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
